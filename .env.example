# Supabase project credentials.
# Get these from Supabase dashboard → Settings → API.
# SUPABASE_URL is the "Project URL"; SUPABASE_KEY is the "anon public" key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Airbnb iCal export URL for this property.
# Host site → Calendar → Availability settings → Sync calendars → Export calendar.
# The `?t=<token>` query string is a credential — anyone with this URL can read
# the property's booking dates. Keep it out of committed files. Rotate from the
# same Airbnb settings screen if it ever leaks.
ICAL_URL=https://www.airbnb.com/calendar/ical/12345678.ics?t=replace-me

# Which property this dashboard instance represents.
# v1: URL-based property routing is deferred to Task 9, so this is set per-deployment.
# Use a hard-to-guess value (e.g. a UUID) — security comes from URL/env secrecy.
PROPERTY_ID=replace-me-with-a-uuid

# Anthropic API key — used server-side to generate the daily briefing.
# Create one at https://console.anthropic.com → API Keys. Server-only; never
# exposed to the browser (all Claude calls run in src/api/claude.ts).
ANTHROPIC_API_KEY=sk-ant-replace-me

# NOTE: production on Cloudflare Workers does NOT read .env at runtime.
# Set production secrets via `wrangler secret put SUPABASE_URL` (and similar)
# or in the Cloudflare dashboard. Tracked in ROADMAP decision log 2026-05-11.
